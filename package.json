{
  "name": "book-editor",
  "private": true,
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api dev",
    "dev:worker": "pnpm --filter api worker",
    "prisma:studio": "pnpm --filter api prisma:studio",
    "prisma:clear": "pnpm --filter api prisma:reset",
    "format": "prettier --write \"**/*.{js,ts,jsx,tsx,css,html}\"",
    "redis": "docker compose up -d",
    "dev": "concurrently \"pnpm dev:web\" \"pnpm dev:api\" \"pnpm dev:worker\"",
    "build": "pnpm --filter web build",
    "pm2:start": "pm2 start ecosystem.config.js --env production",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:restart": "pm2 restart ecosystem.config.js --env production",
    "pm2:reload": "pm2 reload ecosystem.config.js --env production",
    "pm2:delete": "pm2 delete ecosystem.config.js",
    "pm2:logs": "pm2 logs",
    "pm2:status": "pm2 status"
  },
  "devDependencies": {
    "concurrently": "latest",
    "prettier": "^3.8.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "msgpackr-extract",
      "prisma",
      "sharp"
    ]
  }
}
